---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Curated AI signal, ranked by importance.'
} = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · AI Radar</title>
    <link rel="alternate" type="application/rss+xml" title="AI Radar RSS" href={`${base}rss.xml`} />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={base} aria-label="AI Radar home">
          <span class="brand-mark"></span>
          <span>AI Radar</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={`${base}feed/`}>Feed</a>
          <a href={`${base}issues/`}>Issues</a>
          <a href={`${base}rss.xml`}>RSS</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f4ee;
    --surface: #fffdfa;
    --ink: #1f2428;
    --muted: #626a70;
    --line: #ded8cc;
    --accent: #2f6f68;
    --accent-soft: #dcece8;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(47, 111, 104, 0.12), transparent 32rem),
      var(--bg);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--accent);
  }

  .shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .site-header nav {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .brand {
    font-weight: 760;
    letter-spacing: -0.04em;
    font-size: 1.1rem;
  }

  .brand-mark {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 6px var(--accent-soft);
  }

  .site-header nav {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 780;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6.6rem);
    max-width: 10ch;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  p {
    color: var(--muted);
    line-height: 1.65;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(32px, 8vw, 96px);
    padding: clamp(56px, 12vw, 132px) 0 72px;
    align-items: end;
  }

  .hero-copy {
    display: grid;
    gap: 24px;
  }

  .hero-copy p {
    max-width: 58ch;
    font-size: 1.1rem;
  }

  .panel {
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    border: 1px solid var(--line);
    border-radius: 28px;
    padding: 24px;
    box-shadow: 0 24px 80px rgba(54, 44, 28, 0.08);
  }

  .stack {
    display: grid;
    gap: 16px;
  }

  .item-list {
    display: grid;
    gap: 14px;
  }

  .item {
    display: grid;
    gap: 10px;
    padding: 20px 0;
    border-top: 1px solid var(--line);
  }

  .item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    color: var(--accent);
    background: var(--accent-soft);
    font-size: 0.78rem;
    font-weight: 720;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section {
    padding: 56px 0;
    border-top: 1px solid var(--line);
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: end;
    margin-bottom: 28px;
  }

  .issue-body {
    max-width: 72ch;
    padding: 56px 0;
  }

  .issue-body :where(p, li) {
    color: var(--ink);
    line-height: 1.75;
  }

  .issue-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 760px) {
    .site-header,
    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero {
      grid-template-columns: 1fr;
      padding-top: 48px;
    }

    h1 {
      max-width: none;
    }
  }
</style>
