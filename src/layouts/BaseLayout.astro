---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Curated AI signal, ranked by importance.'
} = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} · AI Radar`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title} · AI Radar</title>
    <link rel="alternate" type="application/rss+xml" title="AI Radar RSS" href={`${base}rss.xml`} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="grain" aria-hidden="true"></div>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={base} aria-label="AI Radar home">
          <span class="brand-mark">AR</span>
          <span class="brand-copy"><strong>AI Radar</strong><small>public briefing archive</small></span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={`${base}feed/`}>Feed</a>
          <a href={`${base}issues/`}>Issues</a>
          <a href={`${base}rss.xml`}>RSS</a>
        </nav>
      </header>
      <main id="content">
        <slot />
      </main>
      <footer class="site-footer">
        <p>Short, source-linked AI briefings. No raw collection logs, private notes, or scoring internals.</p>
        <a href={`${base}issues/`}>Browse archive</a>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #ebe5d9;
    --paper: #fbf7ee;
    --paper-strong: #fffdf7;
    --ink: #17191b;
    --muted: #65625a;
    --faint: #8d887c;
    --line: #d6cdbc;
    --line-strong: #b9ad98;
    --accent: #8d3f22;
    --accent-soft: #f1d8c8;
    --olive: #4f5a43;
    --shadow: 0 28px 90px rgba(58, 45, 24, 0.12);
    --serif: Georgia, "Iowan Old Style", "New York", serif;
    --sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --mono: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 12% 0%, rgba(141, 63, 34, 0.16), transparent 30rem),
      radial-gradient(circle at 84% 18%, rgba(79, 90, 67, 0.13), transparent 34rem),
      linear-gradient(180deg, #f2ecdf 0%, var(--bg) 54%, #e2d9c8 100%);
    color: var(--ink);
    font-family: var(--sans);
    text-rendering: optimizeLegibility;
  }

  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.22;
    background-image:
      linear-gradient(90deg, rgba(23, 25, 27, 0.035) 1px, transparent 1px),
      linear-gradient(rgba(23, 25, 27, 0.025) 1px, transparent 1px);
    background-size: 37px 37px;
    mask-image: linear-gradient(to bottom, black, transparent 82%);
  }

  a { color: inherit; text-decoration: none; }

  a:hover { color: var(--accent); }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
    outline-offset: 4px;
    border-radius: 10px;
  }

  .skip-link {
    position: absolute;
    left: 16px;
    top: -48px;
    z-index: 10;
    padding: 10px 14px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 999px;
  }

  .skip-link:focus { top: 16px; }

  .shell {
    position: relative;
    z-index: 1;
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 26px 0 22px;
    border-bottom: 1px solid var(--line-strong);
  }

  .brand,
  .site-header nav {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--ink);
    border-radius: 14px;
    background: var(--ink);
    color: var(--paper);
    font: 700 0.78rem/1 var(--mono);
    letter-spacing: -0.05em;
    box-shadow: 5px 5px 0 var(--accent-soft);
  }

  .brand-copy { display: grid; gap: 2px; }

  .brand-copy strong {
    font-family: var(--serif);
    font-size: 1.24rem;
    letter-spacing: -0.04em;
  }

  .brand-copy small,
  .site-footer,
  .meta {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .site-header nav {
    padding: 6px;
    background: rgba(251, 247, 238, 0.72);
    border: 1px solid var(--line);
    border-radius: 999px;
    box-shadow: 0 10px 40px rgba(58, 45, 24, 0.06);
  }

  .site-header nav a {
    padding: 9px 13px;
    border-radius: 999px;
    color: var(--muted);
    transition: color 180ms ease, background 180ms ease, transform 180ms ease;
  }

  .site-header nav a:hover {
    background: var(--paper-strong);
    color: var(--ink);
    transform: translateY(-1px);
  }

  .eyebrow {
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    color: var(--ink);
    font-family: var(--serif);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  h1 { font-size: clamp(3.2rem, 9vw, 7.8rem); max-width: 11ch; }
  h2 { font-size: clamp(2rem, 4vw, 3.8rem); }
  h3 { font-size: clamp(1.35rem, 2vw, 1.95rem); line-height: 1.08; }

  p { color: var(--muted); line-height: 1.72; text-wrap: pretty; }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.16fr) minmax(300px, 0.84fr);
    gap: clamp(32px, 7vw, 88px);
    padding: clamp(64px, 12vw, 132px) 0 80px;
    align-items: end;
  }

  .hero-copy { display: grid; gap: 22px; }

  .hero-copy p {
    max-width: 60ch;
    font-size: clamp(1.05rem, 1.6vw, 1.24rem);
  }

  .panel {
    position: relative;
    background: color-mix(in srgb, var(--paper-strong) 90%, transparent);
    border: 1px solid var(--line-strong);
    border-radius: 30px;
    padding: 28px;
    box-shadow: var(--shadow);
  }

  .panel::before {
    content: "";
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(185, 173, 152, 0.42);
    border-radius: 22px;
    pointer-events: none;
  }

  .stack { display: grid; gap: 18px; }

  .section {
    padding: 64px 0 78px;
    border-top: 1px solid var(--line-strong);
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    margin-bottom: 34px;
  }

  .section-head a,
  .panel a,
  .issue-body a[href^="http"] {
    color: var(--accent);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  .item-list {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .item {
    grid-column: span 6;
    display: grid;
    align-content: start;
    gap: 14px;
    min-height: 100%;
    padding: 24px;
    background: rgba(251, 247, 238, 0.72);
    border: 1px solid var(--line);
    border-radius: 24px;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .item:nth-child(3n + 1) { grid-column: span 7; }
  .item:nth-child(3n + 2) { grid-column: span 5; }

  .item:hover {
    transform: translateY(-3px);
    border-color: var(--line-strong);
    background: var(--paper-strong);
  }

  .item p { margin: 0; }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    margin-top: 4px;
    font-variant-numeric: tabular-nums;
  }

  .meta span,
  .pill {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255, 253, 247, 0.64);
  }

  .pill {
    color: var(--accent);
    background: var(--accent-soft);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .issue-body {
    max-width: 76ch;
    padding: 64px 0 92px;
  }

  .issue-body > .eyebrow { display: inline-block; margin-bottom: 18px; }

  .issue-body > h1 { max-width: 12ch; margin-bottom: 18px; }

  .issue-body > p:first-of-type {
    font-size: 1.18rem;
    color: var(--muted);
    max-width: 62ch;
    margin-bottom: 46px;
  }

  .issue-body :where(h2) {
    margin-top: 54px;
    padding-top: 28px;
    border-top: 1px solid var(--line-strong);
  }

  .issue-body :where(h3) {
    margin-top: 32px;
    padding: 20px 0 0;
    border-top: 1px solid var(--line);
  }

  .issue-body :where(p, li) {
    color: var(--ink);
    line-height: 1.76;
  }

  .issue-body strong { color: var(--muted); font-weight: 650; }

  .issue-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 34px 0 54px;
    border-top: 1px solid var(--line-strong);
  }

  .site-footer p { margin: 0; max-width: 62ch; }
  .site-footer a { font-weight: 700; color: var(--ink); }

  .issue-card h2 { font-size: clamp(1.9rem, 3vw, 3rem); }

  .tag-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 26px 0 34px;
  }

  .tag-strip.compact { margin-top: 0; }

  .tag-strip span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 11px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 253, 247, 0.68);
    color: var(--muted);
    font-size: 0.84rem;
  }

  .tag-strip small {
    display: grid;
    place-items: center;
    min-width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .briefing-groups {
    display: grid;
    gap: 26px;
  }

  .home-groups {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .briefing-group {
    display: grid;
    gap: 18px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: rgba(251, 247, 238, 0.66);
  }

  .issue-body .briefing-group h2,
  .issue-body .editorial-boundary h2 {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .group-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 18px;
  }

  .group-head h2,
  .group-head h3 {
    margin-top: 6px;
  }

  .group-count {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    height: 2.2rem;
    padding: 0 10px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .compact-list {
    display: grid;
    gap: 12px;
  }

  .compact-item {
    display: grid;
    gap: 10px;
    padding: 18px 0 0;
    border-top: 1px solid var(--line);
  }

  .compact-item h3,
  .compact-item h4 {
    margin: 0;
    color: var(--ink);
    font-family: var(--serif);
    font-size: clamp(1.18rem, 1.7vw, 1.55rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .compact-item p { margin: 0; }

  .editorial-boundary {
    margin-top: 34px;
    padding: 24px;
    border: 1px solid var(--line-strong);
    border-radius: 24px;
    background: var(--paper-strong);
  }

  .feed-grid .item:nth-child(n) { grid-column: span 6; }

  @media (max-width: 820px) {
    .home-groups { grid-template-columns: 1fr; }
    .feed-grid .item:nth-child(n) { grid-column: 1 / -1; }
  }


  .feed-page .section-head p {
    margin: 12px 0 0;
    max-width: 48rem;
  }

  .filter-bar {
    position: sticky;
    top: 0;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: -8px 0 34px;
    padding: 14px 0;
    background: linear-gradient(180deg, rgba(235, 229, 217, 0.96), rgba(235, 229, 217, 0.78));
    backdrop-filter: blur(14px);
  }

  .filter-chip {
    appearance: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255, 253, 247, 0.78);
    color: var(--muted);
    cursor: pointer;
    font: 700 0.78rem/1 var(--sans);
    transition: background 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .filter-chip:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    color: var(--ink);
  }

  .filter-chip.is-active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 18px;
    max-width: 920px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 140px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--line-strong);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 118px minmax(0, 1fr);
    gap: 44px;
    align-items: start;
  }

  .timeline-item[hidden] { display: none; }

  .timeline-item time {
    position: sticky;
    top: 78px;
    color: var(--faint);
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-align: right;
  }

  .timeline-card {
    position: relative;
    display: grid;
    gap: 12px;
    padding: 22px 24px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: rgba(251, 247, 238, 0.76);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    left: -51px;
    top: 26px;
    width: 13px;
    height: 13px;
    border: 2px solid var(--accent);
    border-radius: 999px;
    background: var(--paper);
  }

  .timeline-card:hover {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    background: var(--paper-strong);
  }

  .timeline-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    color: var(--faint);
    font-family: var(--mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .timeline-card h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 2rem);
    line-height: 1.05;
  }

  .timeline-card p { margin: 0; color: var(--ink); }

  .tag-meta { margin-top: 4px; }

  @media (max-width: 820px) {
    .filter-bar { position: relative; }
    .timeline::before { left: 7px; }
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 8px;
      padding-left: 28px;
    }
    .timeline-item time {
      position: static;
      text-align: left;
    }
    .timeline-card::before {
      left: -27px;
      top: 24px;
    }
  }

  @media (max-width: 820px) {
    .shell { width: min(100% - 28px, 1180px); }
    .site-header,
    .section-head,
    .site-footer { align-items: flex-start; grid-template-columns: 1fr; flex-direction: column; }
    .hero { grid-template-columns: 1fr; padding-top: 52px; }
    h1 { max-width: none; }
    .item,
    .item:nth-child(n) { grid-column: 1 / -1; }
    .site-header nav { width: 100%; justify-content: space-between; }
  }
</style>
