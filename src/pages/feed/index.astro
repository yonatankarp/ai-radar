---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { groupItems } from '../../lib/radar';

const items = (await getCollection('items'))
  .sort((a, b) => new Date(b.data.discoveredAt).valueOf() - new Date(a.data.discoveredAt).valueOf());
const groups = groupItems(items, 999);
---
<BaseLayout title="Feed" description="Curated AI Radar feed.">
  <section class="section">
    <div class="section-head">
      <div>
        <span class="eyebrow">Curated feed</span>
        <h1>Feed</h1>
      </div>
    </div>
    <div class="briefing-groups">
      {groups.map((group) => (
        <section class="briefing-group" aria-labelledby={`feed-${group.key}`}>
          <div class="group-head">
            <div>
              <span class="eyebrow">{group.shortLabel}</span>
              <h2 id={`feed-${group.key}`}>{group.label}</h2>
            </div>
            <span class="group-count">{group.total}</span>
          </div>
          <p>{group.description}</p>
          <div class="item-list feed-grid">
            {group.items.map((item) => (
              <article class="item">
                <span class="pill">{item.data.importance}</span>
                <h3><a href={item.data.url}>{item.data.title}</a></h3>
                <p>{item.data.whyItMatters}</p>
                <div class="meta">
                  <span>{item.data.source}</span>
                  <span>{new Date(item.data.discoveredAt).toLocaleDateString('en-GB')}</span>
                  {item.data.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
