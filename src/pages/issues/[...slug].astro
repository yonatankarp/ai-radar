---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatIssueDate, groupItems, topTags } from '../../lib/radar';

export async function getStaticPaths() {
  const issues = await getCollection('issues', ({ data }) => data.status === 'published');
  const items = await getCollection('items');
  return issues.map((issue) => {
    const slug = issue.id.replace(/\.md$/, '');
    return {
      params: { slug },
      props: {
        issue,
        items: items
          .filter((item) => item.data.issue === slug)
          .sort((a, b) => new Date(b.data.discoveredAt).valueOf() - new Date(a.data.discoveredAt).valueOf())
      }
    };
  });
}

const { issue, items } = Astro.props;
const dateLabel = formatIssueDate(issue.data.publishedAt);
const groups = groupItems(items);
const tags = topTags(items);
const leadTags = tags.slice(0, 3).map(([tag]) => tag);
const lead = leadTags.length
  ? `Today’s issue is strongest around ${leadTags.join(', ')}. Open the sections that match your lane and skip the rest.`
  : 'Today’s issue collects the AI items most worth opening.';
---
<BaseLayout title={dateLabel} description={issue.data.description}>
  <article class="issue-body issue-summary">
    <span class="eyebrow">Daily issue</span>
    <h1>{dateLabel}</h1>
    <p>{lead}</p>

    {tags.length > 0 && (
      <div class="tag-strip" aria-label="Top tags in this issue">
        {tags.map(([tag, count]) => <span>{tag} <small>{count}</small></span>)}
      </div>
    )}

    <div class="briefing-groups">
      {groups.map((group) => (
        <section class="briefing-group" aria-labelledby={`${group.key}-heading`}>
          <div class="group-head">
            <div>
              <h2 id={`${group.key}-heading`}>{group.label}</h2>
            </div>
            <span class="group-count">{group.items.length}{group.total > group.items.length ? ` of ${group.total}` : ''}</span>
          </div>
          <div class="compact-list">
            {group.items.map((item) => (
              <article class="compact-item">
                <h3><a href={item.data.url}>{item.data.title}</a></h3>
                <p>{item.data.whyItMatters}</p>
                <div class="meta">
                  <span>{item.data.source}</span>
                  {item.data.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
