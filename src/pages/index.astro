---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const issues = (await getCollection('issues', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const items = (await getCollection('items'))
  .sort((a, b) => new Date(b.data.discoveredAt).valueOf() - new Date(a.data.discoveredAt).valueOf());
const latestIssue = issues[0];
---
<BaseLayout title="Curated AI briefings" description="A public feed of AI news important enough to matter.">
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Signal over volume</span>
      <h1>AI news, only when it clears the bar.</h1>
      <p>
        AI Radar is a curated feed and daily briefing archive for important AI developments. The goal is not to mirror the firehose. The goal is to explain what is worth attention and why.
      </p>
    </div>
    <aside class="panel stack" aria-label="Latest issue">
      <span class="pill">Latest issue</span>
      {latestIssue ? (
        <>
          <h2>{latestIssue.data.title}</h2>
          <p>{latestIssue.data.description}</p>
          <a href={`/issues/${latestIssue.id.replace(/\.md$/, '')}/`}>Read the issue</a>
        </>
      ) : (
        <p>No published issues yet.</p>
      )}
    </aside>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <span class="eyebrow">Curated feed</span>
        <h2>Important enough to publish</h2>
      </div>
      <a href="/feed/">View all</a>
    </div>
    <div class="item-list">
      {items.slice(0, 6).map((item) => (
        <article class="item">
          <span class="pill">{item.data.importance}</span>
          <h3><a href={item.data.url}>{item.data.title}</a></h3>
          <p>{item.data.summary}</p>
          <p><strong>Why it matters:</strong> {item.data.whyItMatters}</p>
          <div class="meta">
            <span>{item.data.source}</span>
            <span>{new Date(item.data.discoveredAt).toLocaleDateString('en-GB')}</span>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
